
{
  "entities": {
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee in the HRMS.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "department": { "type": "string" },
        "jobTitle": { "type": "string" },
        "joinDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "department", "joinDate"]
    },
    "Attendance": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Attendance",
      "type": "object",
      "description": "Represents a daily attendance record for an employee.",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Late"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "employeeId", "date", "status", "timestamp"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents an internal HR task or onboarding requirement.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}/employees/{employeeId}": {
      "schema": "#/backend/entities/Employee",
      "description": "Collection of employees for a given HR admin."
    },
    "/users/{userId}/attendance/{attendanceId}": {
      "schema": "#/backend/entities/Attendance",
      "description": "Global attendance logs indexed by date/employee for the HR admin."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "#/backend/entities/Task",
      "description": "Collection of internal tasks for the HR admin."
    }
  }
}
